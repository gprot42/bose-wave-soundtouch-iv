{
  "name": "soundtouch-controller",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "node build",
    "start": "node build",
    "build:mobile": "BUILD_TARGET=mobile vite build",
    "build:android": "npm run build:mobile && npx cap sync android && cd android && JAVA_HOME=${JAVA_HOME:-/opt/homebrew/opt/openjdk@21/libexec/openjdk.jdk/Contents/Home} ./gradlew assembleDebug",
    "deploy:android": "npm run build:android && adb uninstall com.soundtouch.controller 2>/dev/null; adb install android/app/build/outputs/apk/debug/app-debug.apk && adb shell pm enable com.soundtouch.controller && adb shell pm enable --user 10 com.soundtouch.controller 2>/dev/null || true",
    "configure:grapheneos": "bash scripts/configure-grapheneos-bose-wifi.sh"
  },
  "devDependencies": {
    "@capacitor-community/sqlite": "^7.0.1",
    "@capacitor/android": "^7.4.3",
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^7.4.3",

    "@capacitor/ios": "^7.4.3",
    "@flowbite-svelte-plugins/datatable": "^0.4.0",
    "@sveltejs/adapter-static": "^3.0.9",
    "@sveltejs/kit": "^2.37.0",
    "@sveltejs/vite-plugin-svelte": "^6.1.4",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/postcss": "^4.1.14",
    "@tailwindcss/typography": "^0.5.16",
    "@tailwindcss/vite": "^4.1.12",
    "@tsconfig/svelte": "^5.0.5",
    "@types/node": "^24.3.0",
    "@typescript-eslint/eslint-plugin": "^8.42.0",
    "@typescript-eslint/parser": "^8.42.0",
    "autoprefixer": "^10.4.21",
    "cpy-cli": "^6.0.0",
    "eslint": "^9.34.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-svelte": "^3.11.0",
    "flowbite-svelte": "^1.13.5",
    "flowbite-svelte-icons": "^3.0.0",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "prettier-plugin-svelte": "^3.4.0",
    "svelte": "^5.38.6",
    "svelte-check": "^4.3.1",
    "tailwind-variants": "^3.1.0",
    "tailwindcss": "^4.1.12",
    "typescript": "~5.8.3",
    "vite": "^7.1.4"
  },
  "dependencies": {
    "@capacitor/core": "^7.4.3",
    "@capacitor/filesystem": "^7.1.4",
    "@capacitor/haptics": "^7.0.2",
    "@capacitor/share": "^7.0.2",
    "@capacitor/splash-screen": "^7.0.2",
    "@capacitor/status-bar": "^7.0.2",
    "@sveltejs/adapter-node": "^5.3.3",
    "fast-xml-parser": "^5.3.3",
    "node-ssdp": "^4.0.1",
    "simple-datatables": "^10.0.0",
    "sql.js": "^1.13.0",
    "svelte-i18n": "^4.0.1"
  }
}
